<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}Welcome!{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text></svg>">
        {% block stylesheets %}
        {% endblock %}

        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}

        {% set frankenphpHotReload = app.request.server.get('FRANKENPHP_HOT_RELOAD') %}
        {% if frankenphpHotReload %}
        <meta name="frankenphp-hot-reload:url" content="{{ frankenphpHotReload }}">
        <script src="https://cdn.jsdelivr.net/npm/idiomorph"></script>
        <script src="https://cdn.jsdelivr.net/npm/frankenphp-hot-reload/+esm" type="module"></script>
        {% endif %}
    </head>
    <body>
        {% set crmCurrentTenant = app.user ? crm_current_tenant() : null %}
        {% set crmAvailableTenants = app.user ? crm_available_tenants() : [] %}
        {% set crmCurrentMembership = app.user ? crm_current_membership() : null %}
        <nav class="navbar navbar-expand-lg bg-body-tertiary border-bottom mb-4">
            <div class="container">
                <a class="navbar-brand fw-semibold" href="{{ path('crm_home') }}">Trusted Procurement CRM</a>
                <div class="navbar-nav me-auto">
                    {% if app.user %}
                        {% if crmCurrentTenant %}
                            <a class="nav-link" href="{{ path('crm_property_index') }}">Properties</a>
                            <a class="nav-link" href="{{ path('crm_rfq_invitation_index') }}">RFQ Invitations</a>
                            {% if crmCurrentMembership and 'ROLE_TENANT_ADMIN' in crmCurrentMembership.roles %}
                                <a class="nav-link" href="{{ path('crm_admin_users') }}">Users</a>
                            {% endif %}
                        {% endif %}
                        <a class="nav-link" href="{{ path('crm_profile') }}">Profile</a>
                    {% endif %}
                </div>
                <div class="navbar-nav ms-auto">
                    {% if app.user %}
                        {% if crmAvailableTenants|length > 1 %}
                            <form method="post" action="{{ path('crm_tenant_select') }}" class="d-flex align-items-center me-3 gap-2">
                                <input type="hidden" name="_token" value="{{ csrf_token('crm_tenant_select') }}">
                                <select class="form-select form-select-sm" name="tenantId" onchange="this.form.submit()">
                                    {% for tenant in crmAvailableTenants %}
                                        <option value="{{ tenant.id }}" {% if crmCurrentTenant and crmCurrentTenant.id == tenant.id %}selected{% endif %}>{{ tenant.name }}</option>
                                    {% endfor %}
                                </select>
                            </form>
                        {% elseif crmCurrentTenant %}
                            <span class="navbar-text me-3">{{ crmCurrentTenant.name }}</span>
                        {% endif %}
                        <span class="navbar-text me-3">{{ app.user.displayName }}</span>
                        <a class="nav-link" href="{{ path('app_logout') }}">Logout</a>
                    {% else %}
                        <a class="nav-link" href="{{ path('app_login') }}">Login</a>
                    {% endif %}
                </div>
            </div>
        </nav>
        <main class="container pb-5">
            {% for type, messages in app.flashes %}
                {% for message in messages %}
                    <div class="alert {{ type == 'success' ? 'alert-success' : 'alert-danger' }}">{{ message }}</div>
                {% endfor %}
            {% endfor %}
            {% if app.user and not crmCurrentTenant %}
                <div class="alert alert-warning">No active HVAC company is available for this account. Update your profile or ask a tenant admin to assign a membership.</div>
            {% endif %}
            {% block body %}{% endblock %}
        </main>
    </body>
</html>
