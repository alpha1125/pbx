{% extends 'base.html.twig' %}

{% block title %}Access Denied{% endblock %}

{% block body %}
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h1 class="h3 mb-3">Access denied</h1>
                    <p class="text-body-secondary mb-4">This account does not have permission to view or change the requested CRM or PBX record.</p>
                    <div class="d-flex gap-2">
                        <a class="btn btn-primary" href="{{ path('crm_home') }}">Back to CRM</a>
                        <a class="btn btn-outline-secondary" href="{{ path('crm_profile') }}">Open Profile</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
