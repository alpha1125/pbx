{% set dispositionLabels = {
    'no_answer': 'No answer',
    'quote_requested': 'Quote requested',
    'follow_up_required': 'Follow-up required',
    'job_booked': 'Job booked',
    'spam': 'Spam',
} %}
<article class="list-group-item px-0">
    <div class="d-flex justify-content-between align-items-start gap-3">
        <div class="flex-grow-1">
            <div class="d-flex flex-wrap gap-2 align-items-center mb-2">
                <span class="badge text-bg-dark">{{ item.itemType|replace({'_':' '})|title }}</span>
                {% if item.disposition %}
                    <span class="badge text-bg-warning">{{ dispositionLabels[item.disposition] ?? item.disposition|replace({'_':' '})|title }}</span>
                {% endif %}
                <span class="small text-body-secondary">{{ item.occurredAt|date('Y-m-d H:i') }}</span>
            </div>

            <div class="fw-semibold">{{ item.bodyText ?: item.itemType|replace({'_':' '})|title }}</div>

            {% if item.metadata %}
                {% set direction = item.metadata.direction ?? null %}
                {% set durationSeconds = item.metadata.durationSeconds ?? null %}
                {% set outcome = item.metadata.outcome ?? null %}
                {% set linkedContact = item.metadata.linkedContact ?? null %}
                <div class="small text-body-secondary mt-1">
                    {% if direction %}Direction: {{ direction }}{% endif %}
                    {% if durationSeconds is not null %}{% if direction %} · {% endif %}Duration: {{ durationSeconds }}s{% endif %}
                    {% if outcome %}{% if direction or durationSeconds is not null %} · {% endif %}Outcome: {{ outcome|replace({'_':' '})|title }}{% endif %}
                    {% if linkedContact %}{% if direction or durationSeconds is not null or outcome %} · {% endif %}Contact: {{ linkedContact }}{% endif %}
                </div>
            {% endif %}

            {% if item.itemType == 'transcript' and item.callTranscript and transcriptMessages[item.callTranscript.id] is defined %}
                <div class="mt-3 border rounded-3 bg-body-tertiary p-3">
                    <div class="fw-semibold mb-2">Transcript Messages</div>
                    <div class="d-grid gap-3">
                        {% for message in transcriptMessages[item.callTranscript.id] %}
                            <div class="d-flex {{ message.side == 'right' ? 'justify-content-end' : 'justify-content-start' }}">
                                <div class="card border-0 {{ message.side == 'right' ? 'bg-primary-subtle' : 'bg-light' }}" style="max-width: 85%;">
                                    <div class="card-body py-2 px-3">
                                        <div class="small text-uppercase text-body-secondary mb-1">{{ message.label }}</div>
                                        <div class="small">{{ message.text|nl2br }}</div>
                                    </div>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                </div>
            {% endif %}

            {% set aiInsights = item.metadata.aiInsights ?? null %}
            {% if aiInsights %}
                <div class="mt-3 border rounded-3 bg-body-tertiary p-3">
                    <div class="d-flex flex-wrap gap-2 align-items-center justify-content-between mb-2">
                        <div class="fw-semibold">Call Insights</div>
                        {% if aiInsights.recommended_disposition %}
                            <span class="badge text-bg-info">{{ aiInsights.recommended_disposition|replace({'_':' '})|title }}</span>
                        {% endif %}
                    </div>

                    {% if aiInsights.summary %}
                        <div class="small mb-2"><span class="fw-semibold">Summary:</span> {{ aiInsights.summary }}</div>
                    {% endif %}
                    {% if aiInsights.customer_intent %}
                        <div class="small mb-2"><span class="fw-semibold">Intent:</span> {{ aiInsights.customer_intent }}</div>
                    {% endif %}
                    {% if aiInsights.next_step %}
                        <div class="small mb-2"><span class="fw-semibold">Next step:</span> {{ aiInsights.next_step }}</div>
                    {% endif %}

                    {% if aiInsights.matched_contacts is not empty %}
                        <div class="small mb-1 fw-semibold">Suggested contacts</div>
                        <ul class="small mb-2 ps-3">
                            {% for match in aiInsights.matched_contacts %}
                                <li>{{ match.displayName }}{% if match.primaryPhone %} ({{ match.primaryPhone }}){% endif %} - {{ match.reason }}</li>
                            {% endfor %}
                        </ul>
                    {% endif %}

                    {% if aiInsights.matched_properties is not empty %}
                        <div class="small mb-1 fw-semibold">Suggested properties</div>
                        <ul class="small mb-0 ps-3">
                            {% for match in aiInsights.matched_properties %}
                                <li>{{ match.displayAddress }} - {{ match.reason }}</li>
                            {% endfor %}
                        </ul>
                    {% endif %}
                </div>
            {% endif %}
        </div>

        <div class="text-end" style="min-width: 220px;">
            <form method="post" action="{{ path('crm_property_timeline_disposition', {id: property.id, itemId: item.id}) }}" class="d-grid gap-2">
                <input type="hidden" name="_token" value="{{ csrf_token('crm_property_timeline_disposition_' ~ item.id) }}">
                <label class="form-label small mb-0" for="disposition-{{ item.id }}">Disposition</label>
                <select class="form-select form-select-sm" id="disposition-{{ item.id }}" name="disposition">
                    <option value="">None</option>
                    <option value="no_answer" {% if item.disposition == 'no_answer' %}selected{% endif %}>No answer</option>
                    <option value="quote_requested" {% if item.disposition == 'quote_requested' %}selected{% endif %}>Quote requested</option>
                    <option value="follow_up_required" {% if item.disposition == 'follow_up_required' %}selected{% endif %}>Follow-up required</option>
                    <option value="job_booked" {% if item.disposition == 'job_booked' %}selected{% endif %}>Job booked</option>
                    <option value="spam" {% if item.disposition == 'spam' %}selected{% endif %}>Spam</option>
                </select>
                <button class="btn btn-sm btn-outline-primary" type="submit">Save</button>
            </form>
        </div>
    </div>
</article>
