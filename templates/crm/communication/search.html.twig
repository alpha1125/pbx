{% extends 'base.html.twig' %}

{% block title %}Communication Search{% endblock %}

{% block body %}
    <div class="d-flex justify-content-between align-items-start mb-4">
        <div>
            <h1 class="h2 mb-1">Communication Search</h1>
            <p class="text-body-secondary mb-0">{{ tenant.name }}</p>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            <form method="get" class="row g-3 mb-4">
                <div class="col-lg-7">
                    <label class="form-label" for="q">Search</label>
                    <input class="form-control" id="q" name="q" value="{{ search }}" placeholder="Phone, address, customer, quote, invoice, transcript text">
                </div>
                <div class="col-lg-3">
                    <label class="form-label" for="activity">Filter</label>
                    <select class="form-select" id="activity" name="activity">
                        <option value="all" {% if activityFilter == 'all' %}selected{% endif %}>All activity</option>
                        <option value="calls" {% if activityFilter == 'calls' %}selected{% endif %}>Calls only</option>
                        <option value="transcripts" {% if activityFilter == 'transcripts' %}selected{% endif %}>Transcripts only</option>
                        <option value="notes" {% if activityFilter == 'notes' %}selected{% endif %}>Notes only</option>
                    </select>
                </div>
                <div class="col-lg-2 d-flex align-items-end">
                    <button class="btn btn-primary w-100" type="submit">Search</button>
                </div>
            </form>

            {% if search %}
                <div class="list-group list-group-flush">
                    {% for item in results %}
                        <div class="list-group-item px-0">
                            <div class="d-flex justify-content-between gap-3">
                                <div>
                                    <div class="fw-semibold">{{ item.itemType|replace({'_':' '})|title }}</div>
                                    <div class="small text-body-secondary">{{ item.property ? item.property.displayAddress : 'No property' }}</div>
                                    <div class="small">{{ item.bodyText ?: 'No body text' }}</div>
                                </div>
                                <div class="small text-body-secondary">{{ item.occurredAt|date('Y-m-d H:i') }}</div>
                            </div>
                        </div>
                    {% else %}
                        <div class="text-body-secondary">No matching communication items found.</div>
                    {% endfor %}
                </div>
            {% else %}
                <div class="text-body-secondary">Search the tenant communication timeline by address, customer, phone number, quote/invoice number, or transcript text.</div>
            {% endif %}
        </div>
    </div>
{% endblock %}
