{% extends 'base.html.twig' %}

{% block title %}{{ title }}{% endblock %}

{% block body %}
    {% set relationshipType = propertyContact.relationshipType ?? 'other' %}
    <div class="row justify-content-center">
        <div class="col-xl-8">
            <a class="link-secondary text-decoration-none" href="{{ path('crm_property_show', {id: property.id}) }}">Back to Property</a>
            <div class="card shadow-sm mt-3">
                <div class="card-body">
                    <h1 class="h3 mb-1">{{ title }}</h1>
                    <p class="text-body-secondary mb-4">{{ property.displayAddress }}</p>
                    <form method="post" action="{{ formAction }}" class="row g-3">
                        <input type="hidden" name="_token" value="{{ csrf_token('crm_contact_form') }}">
                        <div class="col-md-4">
                            <label class="form-label" for="firstName">First Name</label>
                            <input class="form-control" id="firstName" name="firstName" value="{{ contact.firstName }}">
                        </div>
                        <div class="col-md-4">
                            <label class="form-label" for="lastName">Last Name</label>
                            <input class="form-control" id="lastName" name="lastName" value="{{ contact.lastName }}">
                        </div>
                        <div class="col-md-4">
                            <label class="form-label" for="displayName">Display Name</label>
                            <input class="form-control" id="displayName" name="displayName" value="{{ contact.displayName }}" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label" for="companyName">Company Name</label>
                            <input class="form-control" id="companyName" name="companyName" value="{{ contact.companyName }}">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label" for="relationshipType">Relationship</label>
                            <select class="form-select" id="relationshipType" name="relationshipType">
                                {% for value, label in {
                                    owner: 'Owner',
                                    tenant: 'Tenant',
                                    property_manager: 'Property Manager',
                                    billing_contact: 'Billing Contact',
                                    realtor: 'Realtor',
                                    emergency_contact: 'Emergency Contact',
                                    other: 'Other'
                                } %}
                                    <option value="{{ value }}" {% if relationshipType == value %}selected{% endif %}>{{ label }}</option>
                                {% endfor %}
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label" for="primaryPhone">Primary Phone</label>
                            <input class="form-control" id="primaryPhone" name="primaryPhone" value="{{ contact.primaryPhone }}">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label" for="primaryEmail">Primary Email</label>
                            <input class="form-control" id="primaryEmail" name="primaryEmail" value="{{ contact.primaryEmail }}">
                        </div>
                        <div class="col-12">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="isPrimary" name="isPrimary" value="1" {% if propertyContact is defined and propertyContact.isPrimary %}checked{% endif %}>
                                <label class="form-check-label" for="isPrimary">Primary contact for this property</label>
                            </div>
                        </div>
                        <div class="col-12">
                            <label class="form-label" for="notes">Notes</label>
                            <textarea class="form-control" id="notes" name="notes" rows="4">{{ contact.notes }}</textarea>
                        </div>
                        {% include 'crm/_form_actions.html.twig' with {
                            cancelPath: path('crm_property_show', {id: property.id}),
                            submitLabel: 'Save Contact'
                        } only %}
                    </form>
                    {% if contact.id %}
                        <hr class="my-4">
                        <form method="post" action="{{ path('crm_contact_archive', {propertyId: property.id, contactId: contact.id}) }}">
                            <input type="hidden" name="_token" value="{{ csrf_token('crm_contact_archive_' ~ contact.id) }}">
                            <div class="d-flex gap-2">
                                <button class="btn btn-outline-danger" type="submit" onclick="return confirm('Archive this contact?')">Archive Contact</button>
                            </div>
                        </form>

                        <hr class="my-4">
                        <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
                            <div>
                                <h2 class="h5 mb-1">CSR Playbooks</h2>
                                <p class="text-body-secondary mb-0">Fixed templates for this contact context. No AI-generated scripts are used.</p>
                            </div>
                        </div>
                        <div class="accordion" id="contact-playbook-accordion">
                            {% for playbook in csrPlaybooks %}
                                <div class="accordion-item">
                                    <h3 class="accordion-header" id="contact-playbook-heading-{{ loop.index }}">
                                        <button class="accordion-button {% if not loop.first %}collapsed{% endif %}" type="button" data-bs-toggle="collapse" data-bs-target="#contact-playbook-collapse-{{ loop.index }}" aria-expanded="{{ loop.first ? 'true' : 'false' }}" aria-controls="contact-playbook-collapse-{{ loop.index }}">
                                            {{ playbook.title }}
                                        </button>
                                    </h3>
                                    <div id="contact-playbook-collapse-{{ loop.index }}" class="accordion-collapse collapse {% if loop.first %}show{% endif %}" aria-labelledby="contact-playbook-heading-{{ loop.index }}" data-bs-parent="#contact-playbook-accordion">
                                        <div class="accordion-body">
                                            <div class="row g-4">
                                                <div class="col-lg-7">
                                                    <div class="mb-3">
                                                        <div class="small text-body-secondary fw-semibold">Purpose</div>
                                                        <div>{{ playbook.purpose }}</div>
                                                    </div>
                                                    <div class="mb-3">
                                                        <div class="small text-body-secondary fw-semibold">Opening Prompt</div>
                                                        <div>{{ playbook.openingPrompt }}</div>
                                                    </div>
                                                    <div class="mb-3">
                                                        <div class="small text-body-secondary fw-semibold">Qualification Questions</div>
                                                        <ul class="mb-0">
                                                            {% for question in playbook.qualificationQuestions %}
                                                                <li>{{ question }}</li>
                                                            {% endfor %}
                                                        </ul>
                                                    </div>
                                                    <div class="mb-3">
                                                        <div class="small text-body-secondary fw-semibold">Objection Handling</div>
                                                        <ul class="mb-0">
                                                            {% for note in playbook.objectionHandlingNotes %}
                                                                <li>{{ note }}</li>
                                                            {% endfor %}
                                                        </ul>
                                                    </div>
                                                    <div class="mb-3">
                                                        <div class="small text-body-secondary fw-semibold">Suggested Next Steps</div>
                                                        <ul class="mb-0">
                                                            {% for step in playbook.suggestedNextSteps %}
                                                                <li>{{ step }}</li>
                                                            {% endfor %}
                                                        </ul>
                                                    </div>
                                                    <div>
                                                        <div class="small text-body-secondary fw-semibold">Compliance Notes</div>
                                                        <ul class="mb-0">
                                                            {% for note in playbook.complianceNotes %}
                                                                <li>{{ note }}</li>
                                                            {% endfor %}
                                                        </ul>
                                                    </div>
                                                </div>
                                                <div class="col-lg-5">
                                                    <div class="border rounded-3 p-3 bg-body-tertiary">
                                                        <div class="d-flex justify-content-between align-items-center gap-2 mb-2">
                                                            <div class="fw-semibold">Contact Attachment</div>
                                                            {% if contactPlaybookAttachments[playbook.type] is defined %}
                                                                <span class="badge text-bg-success">Attached</span>
                                                            {% else %}
                                                                <span class="badge text-bg-secondary">Available</span>
                                                            {% endif %}
                                                        </div>
                                                        {% if contactPlaybookAttachments[playbook.type] is defined %}
                                                            <div class="small text-body-secondary">Already attached to this contact.</div>
                                                        {% else %}
                                                            <form method="post" action="{{ path('crm_csr_playbook_attach') }}" class="mt-2">
                                                                <input type="hidden" name="_token" value="{{ csrf_token('crm_csr_playbook_attach_' ~ playbook.type ~ '_0_' ~ contact.id ~ '_0') }}">
                                                                <input type="hidden" name="_returnTo" value="{{ path('crm_property_show', {id: property.id}) }}">
                                                                <input type="hidden" name="playbookType" value="{{ playbook.type }}">
                                                                <input type="hidden" name="contactId" value="{{ contact.id }}">
                                                                <button class="btn btn-sm btn-outline-primary" type="submit">Attach to Contact</button>
                                                            </form>
                                                        {% endif %}
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            {% endfor %}
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
{% endblock %}
