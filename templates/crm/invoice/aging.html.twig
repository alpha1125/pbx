{% extends 'base.html.twig' %}

{% block title %}Invoice Aging{% endblock %}

{% block body %}
    <div class="d-flex justify-content-between align-items-start mb-4">
        <div>
            <a class="link-secondary text-decoration-none" href="{{ path('crm_home') }}">Back to CRM</a>
            <h1 class="h2 mt-2 mb-1">Invoice Aging</h1>
            <p class="text-body-secondary mb-0">Open balances grouped by delinquency bucket.</p>
        </div>
    </div>

    <div class="row g-4">
        {% for label, rows in agingBuckets %}
            <div class="col-lg-6">
                <div class="card shadow-sm h-100">
                    <div class="card-body">
                        <h2 class="h5">{{ label|replace({'-':' to '})|title }}</h2>
                        <div class="list-group list-group-flush">
                            {% for row in rows %}
                                <div class="list-group-item px-0">
                                    <div class="d-flex justify-content-between gap-3">
                                        <div>
                                            <div class="fw-semibold">
                                                <a href="{{ path('crm_invoice_show', {id: row.invoice.id}) }}">{{ row.invoice.invoiceNumber }}</a>
                                            </div>
                                            <div class="small text-body-secondary">{{ row.invoice.property.displayAddress }}</div>
                                            <div class="small">
                                                {% if row.invoice.dueAt %}Due {{ row.invoice.dueAt|date('Y-m-d') }}{% else %}No due date{% endif %}
                                                · {{ row.invoice.status|replace({'_':' '})|title }}
                                            </div>
                                        </div>
                                        <div class="text-end">
                                            <div class="fw-semibold">${{ (row.invoice.balanceCents / 100)|number_format(2) }}</div>
                                            {% if row.days > 0 %}
                                                <div class="small text-danger">{{ row.days }} day(s) overdue</div>
                                            {% endif %}
                                            {% if row.invoice.contact and row.invoice.contact.primaryEmail %}
                                                <form method="post" action="{{ path('crm_invoice_remind', {id: row.invoice.id}) }}" class="mt-2">
                                                    <input type="hidden" name="_token" value="{{ csrf_token('invoice_remind_' ~ row.invoice.id) }}">
                                                    <button class="btn btn-sm btn-outline-warning" type="submit">Reminder</button>
                                                </form>
                                            {% endif %}
                                        </div>
                                    </div>
                                </div>
                            {% else %}
                                <div class="text-body-secondary">No invoices in this bucket.</div>
                            {% endfor %}
                        </div>
                    </div>
                </div>
            </div>
        {% endfor %}
    </div>
{% endblock %}
