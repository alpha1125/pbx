{% extends 'base.html.twig' %}

{% block title %}Jobs{% endblock %}

{% block body %}
    <div class="d-flex justify-content-between align-items-start mb-4">
        <div>
            <h1 class="h2 mb-1">Dispatch Board</h1>
            <p class="text-body-secondary mb-0">{{ tenant.name }}</p>
        </div>
        <a class="btn btn-outline-primary" href="{{ path('crm_job_queue') }}">Technician Queue</a>
    </div>

    <div class="card shadow-sm">
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead>
                    <tr>
                        <th>Job</th>
                        <th>Property</th>
                        <th>Status</th>
                        <th>Assigned</th>
                        <th>Schedule</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    {% for job in jobs %}
                        <tr>
                            <td>
                                <div class="fw-semibold">{{ job.title ?: 'Untitled job' }}</div>
                                <div class="small text-body-secondary">Job #{{ job.id }}</div>
                            </td>
                            <td>{{ job.property.displayAddress }}</td>
                            <td>{{ job.statusLabel }}</td>
                            <td>{{ job.assignedTo ? job.assignedTo.displayName : 'Unassigned' }}</td>
                            <td>
                                <div>{{ job.scheduledStartAt ? job.scheduledStartAt|date('Y-m-d H:i') : 'No start' }}</div>
                                <div class="small text-body-secondary">{{ job.scheduledEndAt ? job.scheduledEndAt|date('Y-m-d H:i') : 'No end' }}</div>
                            </td>
                            <td class="text-end">
                                <a class="btn btn-sm btn-outline-secondary" href="{{ path('crm_job_show', {id: job.id}) }}">Open</a>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="6" class="text-center text-body-secondary py-4">No jobs yet.</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% endblock %}
