{% extends 'base.html.twig' %}

{% block title %}Properties{% endblock %}

{% block body %}
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h2 mb-1">Properties</h1>
            <p class="text-body-secondary mb-0">{{ tenant.name }}</p>
        </div>
        <div class="d-flex gap-2">
            <a class="btn btn-primary" href="{{ path('crm_property_new') }}">Add Property</a>
            <a class="btn btn-outline-secondary" href="{{ path('crm_rfq_invitation_index') }}">View RFQ Invitations</a>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead>
                    <tr>
                        <th>Address</th>
                        <th>Primary Contact</th>
                        <th>Equipment</th>
                        <th>Updated</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    {% for property in properties %}
                        {% set primaryContact = primaryContacts[property.id] ?? null %}
                        <tr>
                            <td>
                                <div class="fw-semibold">{{ property.displayAddress }}</div>
                                <div class="small text-body-secondary">{{ property.propertyType ?: 'Property' }}</div>
                            </td>
                            <td>
                                {% if primaryContact %}
                                    {{ primaryContact.contact.displayName }}
                                {% else %}
                                    <span class="text-body-secondary">None</span>
                                {% endif %}
                            </td>
                            <td>{{ equipmentCounts[property.id] ?? 0 }}</td>
                            <td>{{ property.updatedAt|date('Y-m-d H:i') }}</td>
                            <td class="text-end">
                                <a class="btn btn-sm btn-primary" href="{{ path('crm_property_show', {id: property.id}) }}">Open</a>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="5" class="text-center text-body-secondary py-4">No properties yet.</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    {% if totalProperties > pageSize %}
        {% set totalPages = (totalProperties / pageSize)|round(0, 'ceil') %}
        <nav class="mt-4" aria-label="Property pagination">
            <ul class="pagination mb-0">
                <li class="page-item {{ page <= 1 ? 'disabled' : '' }}">
                    <a class="page-link" href="{{ path('crm_property_index', {page: page - 1}) }}">Previous</a>
                </li>
                {% for currentPage in 1..totalPages %}
                    <li class="page-item {{ currentPage == page ? 'active' : '' }}">
                        <a class="page-link" href="{{ path('crm_property_index', {page: currentPage}) }}">{{ currentPage }}</a>
                    </li>
                {% endfor %}
                <li class="page-item {{ page >= totalPages ? 'disabled' : '' }}">
                    <a class="page-link" href="{{ path('crm_property_index', {page: page + 1}) }}">Next</a>
                </li>
            </ul>
        </nav>
    {% endif %}
{% endblock %}
