{% extends 'base.html.twig' %}

{% block title %}{{ property.displayAddress }}{% endblock %}

{% block body %}
    <div class="d-flex justify-content-between align-items-start mb-4">
        <div>
            <a class="link-secondary text-decoration-none" href="{{ path('crm_property_index') }}">Back to Properties</a>
            <h1 class="h2 mt-2 mb-1">{{ property.displayAddress }}</h1>
            <p class="text-body-secondary mb-0">{{ property.propertyType ?: 'Property' }}</p>
        </div>
        <div class="d-flex gap-2">
            <a class="btn btn-outline-primary" href="{{ path('crm_property_edit', {id: property.id}) }}">Edit Property</a>
            <form method="post" action="{{ path('crm_property_archive', {id: property.id}) }}">
                <input type="hidden" name="_token" value="{{ csrf_token('crm_property_archive_' ~ property.id) }}">
                <button class="btn btn-outline-danger" type="submit" onclick="return confirm('Archive this property?')">Archive</button>
            </form>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-6">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h2 class="h5 mb-0">Contacts</h2>
                        <a class="btn btn-sm btn-outline-primary" href="{{ path('crm_contact_new', {propertyId: property.id}) }}">Add Contact</a>
                    </div>
                    <div class="list-group list-group-flush">
                        {% for propertyContact in propertyContacts %}
                            <div class="list-group-item px-0">
                                <div class="d-flex justify-content-between align-items-start gap-3">
                                    <div>
                                        <div class="fw-semibold">{{ propertyContact.contact.displayName }}</div>
                                        <div class="small text-body-secondary">{{ propertyContact.relationshipType|replace({'_':' '})|title }}</div>
                                        <div class="small">{{ propertyContact.contact.primaryPhone ?: 'No phone' }}</div>
                                        <div class="small">{{ propertyContact.contact.primaryEmail ?: 'No email' }}</div>
                                    </div>
                                    <div class="text-end">
                                        {% if propertyContact.isPrimary %}
                                            <span class="badge text-bg-primary">Primary</span>
                                        {% endif %}
                                        <div class="mt-2">
                                            <a class="btn btn-sm btn-outline-secondary" href="{{ path('crm_contact_edit', {propertyId: property.id, contactId: propertyContact.contact.id}) }}">Edit</a>
                                        </div>
                                        <form method="post" action="{{ path('crm_property_contact_archive', {propertyId: property.id, contactId: propertyContact.contact.id}) }}" class="mt-2">
                                            <input type="hidden" name="_token" value="{{ csrf_token('crm_property_contact_archive_' ~ property.id ~ '_' ~ propertyContact.contact.id) }}">
                                            <button class="btn btn-sm btn-outline-danger" type="submit" onclick="return confirm('Archive this property-contact link?')">Archive Link</button>
                                        </form>
                                        {% if propertyContact.contact.primaryPhone %}
                                            <form method="post" action="{{ path('crm_property_contact_click_to_call', {propertyId: property.id, contactId: propertyContact.contact.id}) }}" class="mt-2">
                                                <input type="hidden" name="_token" value="{{ csrf_token('crm_click_to_call_' ~ property.id ~ '_' ~ propertyContact.contact.id) }}">
                                                <button class="btn btn-sm btn-outline-primary" type="submit">Click to Call</button>
                                            </form>
                                        {% endif %}
                                    </div>
                                </div>
                            </div>
                        {% else %}
                            <div class="text-body-secondary">No contacts linked.</div>
                        {% endfor %}
                    </div>
                    {% if totalPropertyContacts > contactPageSize %}
                        {% set totalContactPages = (totalPropertyContacts / contactPageSize)|round(0, 'ceil') %}
                        <nav class="mt-3" aria-label="Property contact pagination">
                            <ul class="pagination pagination-sm mb-0">
                                <li class="page-item {{ contactPage <= 1 ? 'disabled' : '' }}">
                                    <a class="page-link" href="{{ path('crm_property_show', {id: property.id, contactPage: contactPage - 1, equipmentPage: equipmentPage}) }}">Previous</a>
                                </li>
                                {% for currentPage in 1..totalContactPages %}
                                    <li class="page-item {{ currentPage == contactPage ? 'active' : '' }}">
                                        <a class="page-link" href="{{ path('crm_property_show', {id: property.id, contactPage: currentPage, equipmentPage: equipmentPage}) }}">{{ currentPage }}</a>
                                    </li>
                                {% endfor %}
                                <li class="page-item {{ contactPage >= totalContactPages ? 'disabled' : '' }}">
                                    <a class="page-link" href="{{ path('crm_property_show', {id: property.id, contactPage: contactPage + 1, equipmentPage: equipmentPage}) }}">Next</a>
                                </li>
                            </ul>
                        </nav>
                    {% endif %}
                </div>
            </div>
        </div>

        <div class="col-lg-6">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h2 class="h5 mb-0">Equipment</h2>
                        <a class="btn btn-sm btn-outline-primary" href="{{ path('crm_equipment_new', {propertyId: property.id}) }}">Add Equipment</a>
                    </div>
                    <div class="list-group list-group-flush">
                        {% for unit in equipment %}
                            <div class="list-group-item px-0">
                                <div class="d-flex justify-content-between align-items-start gap-3">
                                    <div>
                                        <div class="fw-semibold">{{ unit.equipmentType|replace({'_':' '})|title }}</div>
                                        <div class="small text-body-secondary">{{ unit.brand ?: 'Unknown brand' }} {{ unit.modelNumber ?: '' }}</div>
                                        <div class="small">Status: {{ unit.status|replace({'_':' '})|title }}</div>
                                    </div>
                                    <a class="btn btn-sm btn-outline-secondary" href="{{ path('crm_equipment_edit', {propertyId: property.id, equipmentId: unit.id}) }}">Edit</a>
                                </div>
                            </div>
                        {% else %}
                            <div class="text-body-secondary">No equipment recorded.</div>
                        {% endfor %}
                    </div>
                    {% if totalEquipment > equipmentPageSize %}
                        {% set totalEquipmentPages = (totalEquipment / equipmentPageSize)|round(0, 'ceil') %}
                        <nav class="mt-3" aria-label="Property equipment pagination">
                            <ul class="pagination pagination-sm mb-0">
                                <li class="page-item {{ equipmentPage <= 1 ? 'disabled' : '' }}">
                                    <a class="page-link" href="{{ path('crm_property_show', {id: property.id, contactPage: contactPage, equipmentPage: equipmentPage - 1}) }}">Previous</a>
                                </li>
                                {% for currentPage in 1..totalEquipmentPages %}
                                    <li class="page-item {{ currentPage == equipmentPage ? 'active' : '' }}">
                                        <a class="page-link" href="{{ path('crm_property_show', {id: property.id, contactPage: contactPage, equipmentPage: currentPage}) }}">{{ currentPage }}</a>
                                    </li>
                                {% endfor %}
                                <li class="page-item {{ equipmentPage >= totalEquipmentPages ? 'disabled' : '' }}">
                                    <a class="page-link" href="{{ path('crm_property_show', {id: property.id, contactPage: contactPage, equipmentPage: equipmentPage + 1}) }}">Next</a>
                                </li>
                            </ul>
                        </nav>
                    {% endif %}
                </div>
            </div>

            <div class="card shadow-sm mt-4">
                <div class="card-body">
                    <h2 class="h5">Service History</h2>
                    <div class="list-group list-group-flush">
                        {% for record in serviceHistoryRecords %}
                            <div class="list-group-item px-0">
                                <div class="d-flex justify-content-between align-items-start gap-3 mb-2">
                                    <div>
                                        <div class="fw-semibold">{{ record.serviceType ?: 'Service visit' }}</div>
                                        <div class="small text-body-secondary">
                                            {{ record.equipment ? record.equipment.equipmentType|replace({'_':' '})|title : 'Property service' }}
                                            {% if record.technician %}
                                                - {{ record.technician.displayName }}
                                            {% endif %}
                                        </div>
                                    </div>
                                    <div class="text-end small text-body-secondary">
                                        <div>{{ record.arrivedAt ? 'Arrived ' ~ record.arrivedAt|date('Y-m-d H:i') : 'Arrival not recorded' }}</div>
                                        <div>{{ record.completedAt ? 'Completed ' ~ record.completedAt|date('Y-m-d H:i') : 'Completion not recorded' }}</div>
                                    </div>
                                </div>
                                {% if record.technicianNotes %}
                                    <div class="small mb-1"><span class="fw-semibold">Notes:</span> {{ record.technicianNotes }}</div>
                                {% endif %}
                                {% if record.recommendedRepairNotes %}
                                    <div class="small mb-1"><span class="fw-semibold">Repair:</span> {{ record.recommendedRepairNotes }}</div>
                                {% endif %}
                                {% if record.recommendedReplacementNotes %}
                                    <div class="small"><span class="fw-semibold">Replacement:</span> {{ record.recommendedReplacementNotes }}</div>
                                {% endif %}
                            </div>
                        {% else %}
                            <div class="text-body-secondary">No service history recorded yet.</div>
                        {% endfor %}
                    </div>
                </div>
            </div>

            <div class="card shadow-sm mt-4">
                <div class="card-body">
                    <h2 class="h5">Follow-up Tasks</h2>
                    <div class="list-group list-group-flush">
                        {% for task in followUpTasks %}
                            <div class="list-group-item px-0">
                                <div class="d-flex justify-content-between align-items-start gap-3">
                                    <div>
                                        <div class="fw-semibold">{{ task.title }}</div>
                                        <div class="small text-body-secondary">{{ task.kindLabel }}</div>
                                        <div class="small">{{ task.job.title ?: 'Untitled job' }}</div>
                                    </div>
                                    <div class="text-end small text-body-secondary">
                                        <div>{{ task.scheduledStartAt ? task.scheduledStartAt|date('Y-m-d H:i') : 'No reminder date' }}</div>
                                        <div>{{ task.assignedTo ? task.assignedTo.displayName : 'Unassigned' }}</div>
                                    </div>
                                </div>
                            </div>
                        {% else %}
                            <div class="text-body-secondary">No follow-up tasks yet.</div>
                        {% endfor %}
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex flex-column flex-lg-row justify-content-between gap-3 mb-4">
                        <div>
                            <h2 class="h5 mb-1">Communication Timeline</h2>
                            <p class="text-body-secondary mb-0">Calls, recordings, transcripts, summaries, and notes for this property.</p>
                        </div>
                        <form method="get" class="d-flex flex-wrap gap-2 align-items-end">
                            <div>
                                <label class="form-label small mb-1" for="timeline-search">Search</label>
                                <input class="form-control form-control-sm" id="timeline-search" name="q" value="{{ timelineSearch }}">
                            </div>
                            <div>
                                <label class="form-label small mb-1" for="timeline-filter">Filter</label>
                                <select class="form-select form-select-sm" id="timeline-filter" name="activity">
                                    <option value="all" {% if timelineFilter == 'all' %}selected{% endif %}>All activity</option>
                                    <option value="calls" {% if timelineFilter == 'calls' %}selected{% endif %}>Calls only</option>
                                    <option value="transcripts" {% if timelineFilter == 'transcripts' %}selected{% endif %}>Transcripts only</option>
                                    <option value="notes" {% if timelineFilter == 'notes' %}selected{% endif %}>Notes only</option>
                                </select>
                            </div>
                            <button class="btn btn-sm btn-outline-primary" type="submit">Apply</button>
                            <a class="btn btn-sm btn-outline-secondary" href="{{ path('crm_property_show', {id: property.id}) }}">Reset</a>
                        </form>
                    </div>

                    <form method="post" action="{{ path('crm_property_timeline_note', {id: property.id}) }}" class="row g-3 mb-4 border rounded-3 p-3 bg-body-tertiary">
                        <input type="hidden" name="_token" value="{{ csrf_token('crm_property_timeline_note_' ~ property.id) }}">
                        <div class="col-12">
                            <label class="form-label" for="noteText">Add Note</label>
                            <textarea class="form-control" id="noteText" name="noteText" rows="3" placeholder="Add a call note, follow-up detail, or context for this property."></textarea>
                        </div>
                        <div class="col-md-6 col-lg-4">
                            <label class="form-label" for="noteDisposition">Disposition</label>
                            <select class="form-select" id="noteDisposition" name="disposition">
                                <option value="">None</option>
                                <option value="no_answer">No answer</option>
                                <option value="quote_requested">Quote requested</option>
                                <option value="follow_up_required">Follow-up required</option>
                                <option value="job_booked">Job booked</option>
                                <option value="spam">Spam</option>
                            </select>
                        </div>
                        <div class="col-12">
                            <button class="btn btn-primary" type="submit">Save Note</button>
                        </div>
                    </form>

                    <div class="list-group list-group-flush">
                        {% for item in timelineItems %}
                            {% include 'crm/communication/_timeline_item.html.twig' with {item: item, property: property, transcriptMessages: transcriptMessages} %}
                        {% else %}
                            <div class="text-body-secondary">No timeline items yet.</div>
                        {% endfor %}
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-6">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <h2 class="h5">Audit Log</h2>
                    <div class="list-group list-group-flush">
                        {% for log in auditLogs %}
                            <div class="list-group-item px-0">
                                <div class="fw-semibold">{{ log.action }}</div>
                                <div class="small text-body-secondary">{{ log.createdAt|date('Y-m-d H:i:s') }}</div>
                            </div>
                        {% else %}
                            <div class="text-body-secondary">No audit entries yet.</div>
                        {% endfor %}
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
