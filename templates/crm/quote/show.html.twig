{% extends 'base.html.twig' %}

{% block title %}{{ quote.quoteNumber }}{% endblock %}

{% block body %}
    <div class="d-flex justify-content-between align-items-start mb-4">
        <div>
            <a class="link-secondary text-decoration-none" href="{{ path('crm_property_show', {id: quote.property.id}) }}">Back to Property</a>
            <h1 class="h2 mt-2 mb-1">{{ quote.quoteNumber }}</h1>
            <p class="text-body-secondary mb-0">{{ quote.status|replace({'_':' '})|title }}</p>
        </div>
        <form method="post" action="{{ path('crm_quote_convert_to_invoice', {id: quote.id}) }}">
            <input type="hidden" name="_token" value="{{ csrf_token('quote_convert_' ~ quote.id) }}">
            <button class="btn btn-primary" type="submit" {% if quote.status != 'accepted' %}disabled{% endif %}>Convert to Invoice</button>
        </form>
    </div>

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h2 class="h5">Line Items</h2>
                    <table class="table align-middle">
                        <thead>
                            <tr>
                                <th>Description</th>
                                <th>Qty</th>
                                <th>Unit Price</th>
                                <th>Total</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for lineItem in lineItems %}
                                <tr>
                                    <td>{{ lineItem.description }}</td>
                                    <td>{{ lineItem.quantity }}</td>
                                    <td>${{ (lineItem.unitPriceCents / 100)|number_format(2) }}</td>
                                    <td>${{ (lineItem.totalCents / 100)|number_format(2) }}</td>
                                </tr>
                            {% else %}
                                <tr>
                                    <td colspan="4" class="text-center text-body-secondary py-4">No line items.</td>
                                </tr>
                            {% endfor %}
                        </tbody>
                        <tfoot>
                            <tr>
                                <th colspan="3" class="text-end">Total</th>
                                <th>${{ (quote.totalCents / 100)|number_format(2) }}</th>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h2 class="h5">Update Status</h2>
                    <form method="post" action="{{ path('crm_quote_update_status', {id: quote.id}) }}" class="d-grid gap-3">
                        <input type="hidden" name="_token" value="{{ csrf_token('quote_status_' ~ quote.id) }}">
                        <select class="form-select" name="status">
                            {% for status in ['draft', 'sent', 'viewed', 'accepted', 'declined', 'expired', 'cancelled'] %}
                                <option value="{{ status }}" {% if quote.status == status %}selected{% endif %}>{{ status|replace({'_':' '})|title }}</option>
                            {% endfor %}
                        </select>
                        <button class="btn btn-outline-primary" type="submit">Save Status</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
