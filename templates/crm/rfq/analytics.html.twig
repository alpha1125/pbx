{% extends 'base.html.twig' %}

{% block title %}Vendor Analytics{% endblock %}

{% block body %}
    <div class="d-flex justify-content-between align-items-start mb-4">
        <div>
            <h1 class="h2 mb-1">Vendor Analytics</h1>
            <p class="text-body-secondary mb-0">Open, accept, quote, and completion metrics for vendor engagement.</p>
        </div>
        <a class="btn btn-outline-primary" href="{{ path('crm_rfq_operator_index') }}">Back to RFQ Ops</a>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-4 col-xl-2">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <div class="small text-body-secondary">Vendors</div>
                    <div class="h3 mb-0">{{ summary.vendors }}</div>
                </div>
            </div>
        </div>
        <div class="col-md-4 col-xl-2">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <div class="small text-body-secondary">Invitations</div>
                    <div class="h3 mb-0">{{ summary.invitationsSent }}</div>
                </div>
            </div>
        </div>
        <div class="col-md-4 col-xl-2">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <div class="small text-body-secondary">Open rate</div>
                    <div class="h3 mb-0">{% if summary.openRate is not null %}{{ (summary.openRate * 100)|number_format(1) }}%{% else %}n/a{% endif %}</div>
                </div>
            </div>
        </div>
        <div class="col-md-4 col-xl-2">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <div class="small text-body-secondary">Accept rate</div>
                    <div class="h3 mb-0">{% if summary.acceptRate is not null %}{{ (summary.acceptRate * 100)|number_format(1) }}%{% else %}n/a{% endif %}</div>
                </div>
            </div>
        </div>
        <div class="col-md-4 col-xl-2">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <div class="small text-body-secondary">Quote rate</div>
                    <div class="h3 mb-0">{% if summary.quoteRate is not null %}{{ (summary.quoteRate * 100)|number_format(1) }}%{% else %}n/a{% endif %}</div>
                </div>
            </div>
        </div>
        <div class="col-md-4 col-xl-2">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <div class="small text-body-secondary">Jobs completed</div>
                    <div class="h3 mb-0">{{ summary.jobsCompleted }}</div>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <form method="get" class="row g-3 align-items-end">
                <div class="col-md-6 col-lg-4">
                    <label class="form-label" for="q">Search vendors</label>
                    <input class="form-control" id="q" name="q" value="{{ search }}" placeholder="Vendor name, legal name, or email">
                </div>
                <div class="col-md-6 col-lg-3">
                    <button class="btn btn-primary" type="submit">Filter</button>
                </div>
            </form>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h2 class="h5 mb-0">Vendor Performance</h2>
                <span class="badge text-bg-secondary">{{ totalVendors }} vendor(s)</span>
            </div>

            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Vendor</th>
                            <th>Invites</th>
                            <th>Open</th>
                            <th>Accept</th>
                            <th>Quotes</th>
                            <th>Response</th>
                            <th>Jobs</th>
                            <th>Completion</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for row in vendors %}
                            <tr>
                                <td>
                                    <div class="fw-semibold">{{ row.tenant.name }}</div>
                                    <div class="small text-body-secondary">{{ row.tenant.email ?: 'No email on file' }}</div>
                                </td>
                                <td>{{ row.invitationsSent }}</td>
                                <td>
                                    <div>{% if row.invitationsSent > 0 %}{{ (row.invitationsViewed / row.invitationsSent * 100)|number_format(1) }}%{% else %}n/a{% endif %}</div>
                                    <div class="small text-body-secondary">{{ row.invitationsViewed }} viewed</div>
                                </td>
                                <td>
                                    <div>{% if row.invitationsSent > 0 %}{{ (row.invitationsAccepted / row.invitationsSent * 100)|number_format(1) }}%{% else %}n/a{% endif %}</div>
                                    <div class="small text-body-secondary">{{ row.invitationsAccepted }} accepted</div>
                                </td>
                                <td>
                                    <div>{% if row.invitationsAccepted > 0 %}{{ (row.quotesCreated / row.invitationsAccepted * 100)|number_format(1) }}%{% else %}n/a{% endif %}</div>
                                    <div class="small text-body-secondary">{{ row.quotesCreated }} quotes</div>
                                </td>
                                <td>
                                    {% if row.firstResponseSamples > 0 %}
                                        {{ (row.firstResponseMinutesTotal / row.firstResponseSamples / 60)|number_format(1) }}h
                                    {% else %}
                                        n/a
                                    {% endif %}
                                </td>
                                <td>
                                    <div>{{ row.jobsCompleted }} / {{ row.jobsCreated }}</div>
                                </td>
                                <td>
                                    <div>{% if row.jobsCreated > 0 %}{{ (row.jobsCompleted / row.jobsCreated * 100)|number_format(1) }}%{% else %}n/a{% endif %}</div>
                                    {% if row.completionSamples > 0 %}
                                        <div class="small text-body-secondary">{{ (row.completionMinutesTotal / row.completionSamples / 60)|number_format(1) }}h avg</div>
                                    {% else %}
                                        <div class="small text-body-secondary">No completed jobs</div>
                                    {% endif %}
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="8" class="text-center text-body-secondary py-4">No vendor analytics data matches the current filters.</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>

            {% if totalVendors > pageSize %}
                <nav class="mt-3" aria-label="Vendor analytics pagination">
                    <ul class="pagination pagination-sm mb-0">
                        <li class="page-item {{ page <= 1 ? 'disabled' : '' }}">
                            <a class="page-link" href="{{ path('crm_rfq_analytics_index', {page: page - 1, q: search}) }}">Previous</a>
                        </li>
                        {% for currentPage in 1..totalPages %}
                            <li class="page-item {{ currentPage == page ? 'active' : '' }}">
                                <a class="page-link" href="{{ path('crm_rfq_analytics_index', {page: currentPage, q: search}) }}">{{ currentPage }}</a>
                            </li>
                        {% endfor %}
                        <li class="page-item {{ page >= totalPages ? 'disabled' : '' }}">
                            <a class="page-link" href="{{ path('crm_rfq_analytics_index', {page: page + 1, q: search}) }}">Next</a>
                        </li>
                    </ul>
                </nav>
            {% endif %}
        </div>
    </div>
{% endblock %}
