{% extends 'base.html.twig' %}

{% block title %}Transcript {{ transcript.id }} Messages{% endblock %}

{% block body %}
    <main class="container py-4 py-lg-5">
        <section class="card border-0 shadow-sm bg-body-tertiary">
            <div class="card-body p-3 p-lg-4">
                <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-start gap-3 border-bottom pb-3 mb-4">
                    <div>
                        <div class="d-flex align-items-center gap-2 mb-2">
                            <span class="badge text-bg-dark">Transcript {{ transcript.id }}</span>
                            <span class="badge text-bg-secondary">{{ transcript.provider ?: 'unknown' }}</span>
                        </div>
                        <h1 class="h2 mb-2">Conversation View</h1>
                        <p class="text-body-secondary mb-0">
                            Recording {{ transcript.callRecording ? transcript.callRecording.id : 'n/a' }}
                            · Session {{ transcript.callSession ? transcript.callSession.id : 'n/a' }}
                            {% if transcript.completedAt %}
                                ·
                                <time
                                    datetime="{{ transcript.completedAt|date(constant('DATE_ATOM')) }}"
                                    data-local-datetime="{{ transcript.completedAt|date(constant('DATE_ATOM')) }}"
                                >{{ transcript.completedAt|date('Y-m-d H:i:s') }} UTC</time>
                            {% endif %}
                        </p>
                    </div>
                    <nav class="d-flex gap-2">
                        <a class="btn btn-outline-secondary btn-sm" href="/transcripts/{{ transcript.id }}">Raw JSON</a>
                    </nav>
                </div>

                <section class="d-flex flex-column gap-3">
            {% if messages is empty %}
                    <div class="alert alert-light border text-center text-body-secondary mb-0">
                        No transcript segments were available for chat rendering.
                    </div>
            {% else %}
                {% for message in messages %}
                    <article class="d-flex {{ message.side == 'right' ? 'justify-content-end' : 'justify-content-start' }}">
                        <div class="card border-0 shadow-sm {{ message.side == 'right' ? 'bg-primary-subtle' : 'bg-light' }} col-11 col-md-9 col-lg-8">
                            <div class="card-body p-3">
                                <header class="d-flex flex-column flex-sm-row justify-content-between gap-1 mb-2">
                                    <span class="fw-semibold text-uppercase small text-body-secondary">{{ message.label }}</span>
                                    <span class="small text-body-secondary">
                                        <time
                                            datetime="{{ message.occurredAt }}"
                                            data-local-datetime="{{ message.occurredAt }}"
                                        >{{ message.occurredAt|date('Y-m-d H:i:s') }} UTC</time>
                                        {% if message.segmentCount > 1 %} · {{ message.segmentCount }} segments{% endif %}
                                    </span>
                                </header>
                                <p class="mb-0 lh-base">{{ message.text|nl2br }}</p>
                            </div>
                        </div>
                    </article>
                {% endfor %}
            {% endif %}
                </section>
            </div>
        </section>
    </main>
{% endblock %}
